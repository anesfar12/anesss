# ═══════════════════════════════════════════════════════════════════════════
# LUXE POS v5.1 — Environment Variables Template
# Copy to .env.local and fill in real values
# Blueprint Section 12 — ~$84–$94/month total infrastructure
# ═══════════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (Supabase — PostgreSQL 18 Pro ~$25/mo) ─────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DB_HOST=db.[PROJECT].supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-db-password
DB_SSL=true
DB_MAX_CONNECTIONS=20

# ── Redis (Upstash — free tier) ──────────────────────────────────────────────
REDIS_URL=redis://default:[PASSWORD]@[HOST].upstash.io:6379
REDIS_HOST=[HOST].upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-upstash-password
REDIS_TLS=true

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_64_BYTE_RANDOM_SECRET
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── AI Microservice ──────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000

# ── Groq (Llama 3.3 + Jais-30b — ~$10–30/mo) ───────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key

# ── OpenAI (text-embedding-3-small) ─────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ── ChromaDB (Hetzner VPS CX22 — ~$5/mo) ────────────────────────────────────
CHROMADB_HOST=localhost
CHROMADB_PORT=8001

# ── AWS KMS (NFC HMAC-SHA256 key signing) ────────────────────────────────────
AWS_KMS_KEY_ID=arn:aws:kms:me-south-1:[ACCOUNT]:key/[KEY-ID]
AWS_REGION=me-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# ── Cloudflare R2 (AR assets — free 10GB) ────────────────────────────────────
CLOUDFLARE_R2_BUCKET=luxe-ar-assets
CLOUDFLARE_R2_ENDPOINT=https://[ACCOUNT_ID].r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY=your-r2-access-key
CLOUDFLARE_R2_SECRET_KEY=your-r2-secret-key
CLOUDFLARE_CDN_URL=https://assets.luxepos.com

# ── Twilio (WhatsApp + SMS — ~$10/mo) ────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC_your_twilio_sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+1234567890

# ── Resend (Email — 3k/mo free) ──────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@luxepos.com

# ── Blockchain (Polygon — public RPC free) ───────────────────────────────────
POLYGON_RPC_URL=https://polygon-rpc.com
BLOCKCHAIN_PRIVATE_KEY=your-wallet-private-key
PASSPORT_CONTRACT_ADDRESS=0x_your_contract_address

# ── IPFS / Pinata (free tier) ─────────────────────────────────────────────────
PINATA_API_KEY=your-pinata-api-key
PINATA_SECRET_KEY=your-pinata-secret-key
PINATA_GATEWAY=https://gateway.pinata.cloud

# ── Frontend URLs ─────────────────────────────────────────────────────────────
POS_APP_URL=http://localhost:3001
DASHBOARD_URL=http://localhost:3002
STOREFRONT_URL=http://localhost:3003

# ── Next.js Public ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000
NEXT_PUBLIC_APP_VERSION=5.1.0

# ── Python AI Service ─────────────────────────────────────────────────────────
# Engineering Fix 8: Do NOT set PYTHON_JIT=1 until Python 3.15+
PYTHON_JIT=0
DATABASE_URL_AI=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,http://api:3000
